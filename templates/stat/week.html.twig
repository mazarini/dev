{% extends 'layout.html.twig' %}

{% block title %}
	Statistiques hebdomadaire
{% endblock title %}

{% block content %}
	<form method="post" action="">
		<div class="form-group">
			<div class="input-group date" id="datetimepicker4" data-target-input="nearest">
				<input type="text" name="date" value="{{ dates[1][1]|date('d/m/Y') }}" class="form-control datetimepicker-input" data-target="#datetimepicker4"/>
				<div class="input-group-append" data-target="#datetimepicker4" data-toggle="datetimepicker">
					<div class="input-group-text">
						<i class="fa fa-calendar"></i>
					</div>
				</div>
				<button class="btn btn-primary" type="submit">Calculer</button>
			</div>
		</div>
	</form>
	<h2>Semaine du {{ dates[1][1]|date('d F Y') }}</h2>
	{% include 'stat/table_week.html.twig' with { 'dates': dates[1], 'amounts': amounts[1] } only %}
	<h2>Semaine précédente</h2>
	{% include 'stat/table_week.html.twig' with { 'dates': dates[2], 'amounts': amounts[2] } only %}
	<h2>Mois précédent ({{ dates[3][1]|date('d F Y') }})</h2>
	{% include 'stat/table_week.html.twig' with { 'dates': dates[3], 'amounts': amounts[3] } only %}
	<h2>Année précédente ({{ dates[4][1]|date('d F Y') }})</h2>
	{% include 'stat/table_week.html.twig' with { 'dates': dates[4], 'amounts': amounts[4] } only %}
{% endblock content %}

{% block javascripts %}
	{{ parent() }}
	<script type="text/javascript">
		$(function () {
$('#datetimepicker4').datetimepicker({format: 'L', locale: 'fr'});
});
	</script>
{% endblock javascripts %}
