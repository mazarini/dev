{% extends 'layout.html.twig' %}

{% block title %}
	Example
{% endblock %}

{% block content %}
	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ data.entity.id }}</td>
			</tr>
			<tr>
				<th>Col1</th>
				<td>{{ data.entity.col1 }}</td>
			</tr>
			<tr>
				<th>Col2</th>
				<td>{{ data.entity.col2 }}</td>
			</tr>
		</tbody>
	</table>
	{% include 'example/_button.html.twig' %}
	<br/>
	<a class="btn btn-primary" href="{{ path('example_index') }}" role=" button">List</a>
	<a class="btn btn-primary" href="{{ path('example_edit', {'id': data.entity.id}) }}" role=" button">edit</a>
	<button type="button" class="btn btn-primary" data-toggle="modal" data-target="#modalId">Delete</button>
{% endblock %}
