<table class="table">
	<thead>
		<tr>
			<th>Id</th>
			<th>Col1</th>
			<th>Col2</th>
			<th>actions</th>
		</tr>
	</thead>
	<tbody>
		{% for entity in data.entities %}
			<tr>
				<td>{{ entity.id }}</td>
				<td>{{ entity.col1 }}</td>
				<td>{{ entity.col2 }}</td>
				<td>
					<a class="btn btn-primary btn-sm" href="{{ data.links['show-' ~ entity.id].url }}" role=" button">Show</a>
					<a class="btn btn-primary btn-sm" href="{{ data.links['edit-' ~ entity.id].url }}" role=" button">Edit</a>
				</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="4">no records found</td>
			</tr>
		{% endfor %}
	</tbody>
	<thead>
		<tr>
			<th colspan="3"></th>
			<th>
				<a class="btn btn-primary btn-sm" href="{{ data.links.new.url }}" role=" button">New</a>
			</th>
		</tr>
	</thead>
</table>
{% embed 'pagination/nav.html.twig' %}{% endembed %}
