{% extends 'layout.html.twig' %}

{% block title %}
	Example index
{% endblock %}
{% block content %}
	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Col1</th>
				<th>Col2</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for entity in data.entities %}
				<tr>
					<td>{{ entity.id }}</td>
					<td>{{ entity.col1 }}</td>
					<td>{{ entity.col2 }}</td>
					<td>
						<a href="{{ path('example_show', {'id': entity.id}) }}">show</a>
						<a href="{{ path('example_edit', {'id': entity.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="4">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	<a href="{{ path('example_new') }}">Create new</a>
{% endblock %}
